<<-
  This program computes the date of Easter for a given year.

  Algorithm from "Practical Astronomy with Your Calculator", 2e
  Peter Duffett-Smith, 1981

->>

int4 a;
int4 b;
int4 c;
int4 d;
int4 e;
int4 f;
int4 g;
int4 h;
int4 i;
int4 k;
int4 l;
int4 m;
int4 n;
int4 p;

int4 year;
read(year);

a := year mod 19;
b := year / 100;   
c := year mod 100;
d := b / 4;        
e := b mod 4;
f := (b+8) / 25;
g := (b - f + 1) / 3;
h := (19 * a + b - d - g + 15) mod 30;
i := c / 4;        k := c mod 4;
l := (32 + 2*e + 2*i - h - k) mod 7;
m := (a + 11*h + 22*l) / 451;
n := (h + l - 7*m + 114)/31;
p := (h + l - 7*m + 114) mod 31;

print(
    a, "\n"
    ,b, "\n"
    ,c, "\n"
    ,d, "\n"
    ,e, "\n"
    ,f, "\n"
    ,g, "\n"
    ,h, "\n"
    ,i, "\n"
    ,k, "\n"
    ,l, "\n"
    ,m, "\n"
    ,n, "\n"
    ,p, "\n"
);

print("Easter is on ", n, "/", p + 1, "\n");
